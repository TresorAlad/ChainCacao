PORT=8080
JWT_SECRET=replace-with-strong-secret
ALLOWED_ORIGINS=http://localhost:3000

# Redis (optionnel, rate limit /verify)
# REDIS_URL=redis://localhost:6379/0

# PostgreSQL (optionnel)
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# --- Hyperledger Fabric Gateway (mode reel) ---
# IMPORTANT: pour utiliser Fabric, ne pas forcer le mock
USE_INMEMORY_FABRIC=false

# QR / liens publics
PUBLIC_VERIFY_BASE_URL=https://chaincacao.tg/verify

# MSP de l'identite cliente (ex: utilisateur Org1)
FABRIC_MSP_ID=Org1MSP

# Endpoint gRPC du peer (souvent 7051). Le prefix dns:/// est courant en prod/K8s.
FABRIC_PEER_ENDPOINT=dns:///peer0.org1.example.com:7051

# Nom TLS/SNI du peer (doit correspondre au certificat TLS du peer)
FABRIC_GATEWAY_PEER=peer0.org1.example.com

# Certificat CA TLS du peer (PEM)
FABRIC_TLS_CERT_PATH=/absolute/path/to/peer/tls/ca.crt

# Identite X.509 (MSP) de l'utilisateur qui va signer les transactions (PEM)
# Option 1: chemins directs
FABRIC_SIGNCERT_PATH=/absolute/path/to/user/msp/signcerts/cert.pem
FABRIC_KEY_PATH=/absolute/path/to/user/msp/keystore/key.pem

# Option 2: repertoires (l'API prend le 1er fichier trouve)
# FABRIC_SIGNCERT_DIR=/absolute/path/to/user/msp/signcerts
# FABRIC_KEYSTORE_DIR=/absolute/path/to/user/msp/keystore

# Channel et chaincode (CDC v2.1: channel recommande)
FABRIC_CHANNEL=chaincacao-channel
FABRIC_CHAINCODE=chaincacao

# Cloudinary (optionnel, upload photo lot)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_UPLOAD_PRESET=

# PDF EUDR : cle RSA PEM (PKCS1 ou PKCS8), optionnel
# EUDR_RSA_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
