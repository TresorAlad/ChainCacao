PORT=8080
JWT_SECRET=replace-with-strong-secret
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL local ou Neon (exemple Neon)
# DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Redis (rate limit /verify)
# REDIS_URL=redis://localhost:6379/0

# Ledger : laisser vide ou true pour demo sans peer Fabric
USE_INMEMORY_FABRIC=true

# QR / liens publics
PUBLIC_VERIFY_BASE_URL=https://chaincacao.tg/verify

# Cloudinary (upload photo lot)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# PDF EUDR : cle RSA PEM (PKCS1 ou PKCS8), optionnel
# EUDR_RSA_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- Hyperledger Fabric Gateway (si USE_INMEMORY_FABRIC=false) ---
# FABRIC_MSP_ID=Org1MSP
# FABRIC_PEER_ENDPOINT=dns:///peer0.org1.example.com:7051
# FABRIC_GATEWAY_PEER=peer0.org1.example.com
# FABRIC_TLS_CERT_PATH=/path/to/ca.crt
# FABRIC_SIGNCERT_PATH=/path/to/signcert.pem
# FABRIC_KEY_PATH=/path/to/key.pem
# FABRIC_CHANNEL=mychannel
# FABRIC_CHAINCODE=chaincacao
