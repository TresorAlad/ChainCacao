# --- Mode recommandé si le front est en HTTPS et l’API en HTTP (évite « Failed to fetch ») ---
# Le navigateur n’appelle que la même origine ; Next relaie vers le backend.
# NEXT_PUBLIC_API_URL=/api/v1
# API_REWRITE_TARGET=http://127.0.0.1:8080/api/v1
# En prod (exemple) :
# API_REWRITE_TARGET=http://13.60.214.56:8080/api/v1

# --- Mode direct (OK en local HTTP→HTTP ou si l’API est en HTTPS) ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080/api/v1

# Si besoin d'un QR code base URL (optionnel)
PUBLIC_VERIFY_BASE_URL=https://chaincacao.tg/verify
